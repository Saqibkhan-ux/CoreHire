datasource db {
  provider = "postgresql"
  
}

generator client {
  provider = "prisma-client-js"
}

// 1. Tenant Definition (The Company Workspace)
model Tenant {
  id          String   @id @default(uuid())
  name        String
  subdomain   String   @unique // e.g., "google" -> google.jobboard.com
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  jobs        Job[]
}

// 2. Multi-tenant User Schema
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      String   // "ADMIN", "RECRUITER", "CANDIDATE"
  tenantId  String?  // Nullable if they are independent global job seekers
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  applications JobApplication[]
}

// 3. Multi-tenant Job Posting Schema
model Job {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String
  salaryMin   Int?
  salaryMax   Int?
  tags        String[]
  createdAt   DateTime @default(now())
  
  tenantId    String   // Every single job MUST belong to a specific company/tenant
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  applications JobApplication[]

  @@index([tenantId]) // Optimized indexing for scoping tenant queries
}

// 4. Job Applications Tracking
model JobApplication {
  id          String   @id @default(uuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  userId      String   // The candidate applying
  user        User     @relation(fields: [userId], references: [id])
  resumeLink  String   // ADDED: Link to portfolio/resume
  coverLetter String?  // ADDED: Optional cover letter text
  status      String   @default("PENDING") // "PENDING", "REVIEWING", "HIRED", "REJECTED"
  createdAt   DateTime @default(now())
}